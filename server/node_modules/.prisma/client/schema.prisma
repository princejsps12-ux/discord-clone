generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MODERATOR
  MEMBER
}

enum ChannelType {
  TEXT
  VOICE
}

enum MessageCategory {
  STUDY
  PLACEMENT
  CASUAL
  UNCATEGORIZED
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String
  imageUrl          String?
  passwordHash      String?
  provider          String          @default("credentials")
  isOnline          Boolean         @default(false)
  lastSeenAt        DateTime?
  streakCurrent     Int             @default(0)
  streakLastDate    DateTime?       @db.Date
  studyMinutesTotal Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  memberships       Member[]
  ownedServers      Server[]
  scheduledCalls    ScheduledCall[]
  bookmarks         Bookmark[]
  notesUploaded     Note[]
}

model Server {
  id             String          @id @default(cuid())
  name           String
  imageUrl       String?
  inviteCode     String          @unique
  ownerId        String
  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members        Member[]
  channels       Channel[]
  messages       Message[]
  scheduledCalls ScheduledCall[]
  notes          Note[]
  polls          Poll[]
  studySessions  StudySession[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([ownerId])
}

model Member {
  id               String               @id @default(cuid())
  userId           String
  serverId         String
  role             Role                 @default(MEMBER)
  joinedAt         DateTime             @default(now())
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  server           Server               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages         Message[]
  reactions        Reaction[]
  channelStates    MemberChannelState[]
  pollsCreated     Poll[]               @relation("PollAuthor")
  pollVotes        PollVote[]
  studySessionsLed StudySession[]       @relation("StudySessionCreator")
  studyParts       StudyParticipant[]

  @@unique([userId, serverId])
  @@index([serverId])
  @@index([userId])
}

model MemberChannelState {
  id          String    @id @default(cuid())
  memberId    String
  channelId   String
  unreadCount Int       @default(0)
  isPinned    Boolean   @default(false)
  isFavorite  Boolean   @default(false)
  lastReadAt  DateTime?
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([memberId, channelId])
  @@index([channelId])
}

model Channel {
  id                    String               @id @default(cuid())
  serverId              String
  name                  String
  type                  ChannelType
  lastMessageAt         DateTime?
  lastMessagePreview    String?
  lastMessageSenderName String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  server                Server               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages              Message[]
  memberStates          MemberChannelState[]
  scheduledCalls        ScheduledCall[]
  notes                 Note[]
  polls                 Poll[]
  studySessions         StudySession[]

  @@index([serverId])
}

model Message {
  id            String               @id @default(cuid())
  content       String
  fileUrl       String?
  edited        Boolean              @default(false)
  receiptStatus MessageReceiptStatus @default(SENT)
  category      MessageCategory      @default(UNCATEGORIZED)
  tags          String[]             @default([])
  isAiAssistant Boolean              @default(false)
  serverId      String
  channelId     String
  memberId      String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  channel       Channel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  server        Server               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  member        Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  reactions     Reaction[]
  bookmarks     Bookmark[]

  @@index([channelId, createdAt(sort: Desc)])
  @@index([serverId])
  @@index([category])
}

enum MessageReceiptStatus {
  SENT
  DELIVERED
  SEEN
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  messageId String
  memberId  String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([messageId, memberId, emoji])
  @@index([messageId])
  @@index([memberId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId])
}

model Note {
  id           String   @id @default(cuid())
  serverId     String
  channelId    String?
  title        String
  fileUrl      String
  mimeType     String?
  uploadedById String
  createdAt    DateTime @default(now())
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel      Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([channelId])
}

model Poll {
  id        String       @id @default(cuid())
  channelId String
  serverId  String
  memberId  String
  question  String
  createdAt DateTime     @default(now())
  channel   Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  server    Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  member    Member       @relation("PollAuthor", fields: [memberId], references: [id], onDelete: Cascade)
  options   PollOption[]
  votes     PollVote[]

  @@index([channelId])
  @@index([serverId])
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  text      String
  sortOrder Int        @default(0)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]

  @@index([pollId])
}

model PollVote {
  id       String     @id @default(cuid())
  pollId   String
  optionId String
  memberId String
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  member   Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([pollId, memberId])
  @@index([pollId])
}

model StudySession {
  id              String             @id @default(cuid())
  serverId        String
  channelId       String
  creatorMemberId String
  title           String             @default("Group study")
  plannedMinutes  Int                @default(25)
  startedAt       DateTime           @default(now())
  endedAt         DateTime?
  server          Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel         Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  creator         Member             @relation("StudySessionCreator", fields: [creatorMemberId], references: [id], onDelete: Cascade)
  participants    StudyParticipant[]

  @@index([channelId])
  @@index([serverId])
}

model StudyParticipant {
  id        String       @id @default(cuid())
  sessionId String
  memberId  String
  joinedAt  DateTime     @default(now())
  leftAt    DateTime?
  session   StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member    Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([sessionId])
}

model ScheduledCall {
  id          String   @id @default(cuid())
  serverId    String
  channelId   String?
  title       String?
  scheduledAt DateTime
  callLink    String
  isVideo     Boolean  @default(false)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel     Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([serverId])
  @@index([scheduledAt])
}
