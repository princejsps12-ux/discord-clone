PORT=4000
CLIENT_URL=http://localhost:5173
# Local Postgres:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/discord_clone?schema=public
# Render + Supabase: the "Direct connection" host db.<ref>.supabase.co is often IPv6-only — Render cannot reach it (Prisma P1001).
# In Supabase Dashboard → Connect → use "Session pooler" (port 5432), not Direct. Password special chars must be URL-encoded (@ → %40).
# DATABASE_URL=postgresql://postgres.usbiyqhmkcjcahknmlzp:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
JWT_SECRET=super-secret-change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
